rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: single get() per request scope ────────────────────
    // Rules v2 supports 'let' inside functions, so we cache the doc
    // in a local binding — one Firestore read instead of two per auth check.

    function staffDoc() {
      return get(/databases/$(database)/documents/staff/$(request.auth.uid));
    }

    function isSuperAdmin() {
      let s = staffDoc();
      return request.auth != null
          && s != null
          && s.data.role   == 'super_admin'
          && s.data.active == true;
    }

    function isStaff() {
      let s = staffDoc();
      return request.auth != null
          && s != null
          && s.data.active == true;
    }

    // Appointments — public can create, staff can read/update
    // Field-level validation prevents arbitrary writes from the browser
    match /appointments/{id} {
      allow create: if request.resource.data.keys().hasAll(['name','phone','specialty','date','status','createdAt'])
                    && request.resource.data.name      is string
                    && request.resource.data.name.size() >= 2
                    && request.resource.data.phone     is string
                    && request.resource.data.specialty is string;
      allow read, update: if isStaff();
      allow delete: if false; // never delete — DPDP audit trail
    }

    // Staff profiles — any staff can read, only super_admin can write
    match /staff/{uid} {
      allow read:   if isStaff();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if false; // never delete — DPDP audit trail
    }

    // Clinic settings — public read (site-data.js needs it for all pages)
    match /settings/{document} {
      allow read:  if true;
      allow write: if isSuperAdmin();
    }

    // Audit log — staff read, append-only (no update/delete ever)
    match /auditLog/{entry} {
      allow read:           if isStaff();
      allow create:         if isStaff();
      allow update, delete: if false;
    }
  }
}
